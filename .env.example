# ── Data ──────────────────────────────────────────────────────────
CRMD_DATA_DIR=/data
CRMD_BENCHMARK_DIR=~/.crmd/benchmarks

# ── Server ────────────────────────────────────────────────────────
CRMD_API_KEY=
CRMD_API_URL=
CRMD_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Fetcher (used by Docker services) ─────────────────────────────
CRMD_FETCH_SYMBOL=BTC/USDT
CRMD_FETCH_PROVIDER=bitfinex
CRMD_FETCH_TIMEFRAME=1h
CRMD_FETCH_FOLLOW=
CRMD_FETCH_SINCE_LAST=true
